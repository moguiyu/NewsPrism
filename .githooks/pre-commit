#!/bin/bash
# Pre-commit hook: lightweight public-repo hygiene checks

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "=== Pre-commit Hygiene Check ==="

STAGED_FILES=$(git diff --cached --name-only)

# Never allow committed local env files.
if echo "$STAGED_FILES" | grep -q "^\.env" && echo "$STAGED_FILES" | grep "^\.env" | grep -qv "^\.env\.example$"; then
    echo -e "${RED}ERROR:${NC} .env files should never be committed."
    echo "  Remove with: git rm --cached .env"
    exit 1
fi

# Remind contributors to keep the schema reference current.
if echo "$STAGED_FILES" | grep -q "^newsprism/repo/" && ! echo "$STAGED_FILES" | grep -q "^docs/generated/db-schema.md$"; then
    echo -e "${YELLOW}TIP:${NC} Repository-layer changes detected; check whether docs/generated/db-schema.md also needs an update."
fi

echo -e "${GREEN}✓${NC} Pre-commit checks passed"
