# NewsPrism environment template
# Copy to .env on your server and fill in the values you need.
# NEVER commit .env.

# Required for a basic HTML-only deployment: LiteLLM / summary provider
LITELLM_MODEL=openai/gpt-4.1-mini
LITELLM_BASE_URL=https://api.openai.com/v1
LITELLM_API_KEY=your_api_key_here

# Optional: use a separate evaluator model for active search
EVALUATOR_MODEL=openai/gpt-4.1-mini

# Required for public links in rendered output / Telegram:
# set this to your final public origin or your direct host URL.
# Example:
# REPORT_BASE_URL=https://news.example.com
REPORT_BASE_URL=http://localhost:8080

# Optional: override the scheduler timezone without editing config/config.yaml
SCHEDULE_TIMEZONE=Europe/Warsaw

# Optional: if you run newsnow outside this compose stack, point to it here.
# The bundled compose file injects NEWSNOW_BASE_URL automatically for the default stack.
# NEWSNOW_BASE_URL=http://127.0.0.1:3001

# Optional: Telegram publishing
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: active search providers
# Leave these blank if you want a simpler deployment with fewer external dependencies.
TAVILY_API_KEY=
BRIGHTDATA_API_KEY=
X_BEARER_TOKEN=
YOUTUBE_API_KEY=
